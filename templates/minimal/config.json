{
  "name": "minimal",
  "version": "1.0",
  "description": "最小架构，适合个人使用和学习",
  "agents": ["main"],
  "memory": {
    "layers": 1,
    "auto_capture": false,
    "auto_compress": false,
    "auto_sync": false
  },
  "cron_tasks": [
    {
      "name": "daily-memory-report",
      "schedule": "0 5 * * *",
      "model": "minimax/MiniMax-M2.5",
      "thinking": "low"
    },
    {
      "name": "MEMORY.md 维护",
      "schedule": "0 22 * * 0",
      "model": "anthropic/claude-opus-4-6",
      "thinking": "medium"
    }
  ],
  "scripts": [],
  "shared_context": false,
  "intel": false,
  "files": {
    "root": [
      "SOUL.md",
      "IDENTITY.md",
      "USER.md",
      "MEMORY.md",
      "HEARTBEAT.md",
      "TOOLS.md"
    ],
    "shared_context": [],
    "intel": [],
    "memory": ["YYYY-MM-DD.md"]
  }
}
